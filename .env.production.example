# =============================================================================
# law-firm-website 生产环境变量
# 用法： cp .env.production.example .env.production
#       填好后： docker compose -f docker-compose.production.yml --env-file .env.production up -d
# =============================================================================

# 主机 IP（IP-only 部署用）
PUBLIC_HOST=120.26.244.170

# 数据库：在 pgsql-pgsql-1 里新建的 lawfirm 用户密码
# 用 init-db.sh 第一次生成后保存到这里
LAWFIRM_DB_PASSWORD=__REPLACE_ME__

# ⚠️ 高危：iron-session 的加密密钥，至少 32 字符强随机
# 生成方式： openssl rand -hex 32
SESSION_SECRET=__REPLACE_ME_WITH_OPENSSL_RAND_HEX_32__

# ⚠️ 高危：当前代码读这个值（src/lib/session/index.ts），与 SESSION_SECRET 不同源
# 短期临时值，建议同步设为强随机串
ADMIN_SECRET=__REPLACE_ME__